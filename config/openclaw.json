  },
  "browser": {
    "enabled": true,
    "executablePath": "/usr/bin/chromium",
    "headless": true,
    "noSandbox": true,
    "attachOnly": true,
    "defaultProfile": "openclaw",
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#FF4500"
      }
    }
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "codex",
    "allowedAgents": [
      "codex",
      "claude"
    ]
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6",
        "fallbacks": [
          "openai/gpt-5.2",
          "anthropic/claude-sonnet-4-5"
        ]
      },
      "models": {
        "anthropic/claude-sonnet-4-5": {
          "alias": "Sonnet"
        },
        "anthropic/claude-opus-4-6": {
          "alias": "Opus"
        },
        "anthropic/claude-haiku-4-5": {
          "alias": "Haiku"
        },
        "openrouter/openai/gpt-5.2-codex": {
          "alias": "Codex"
        }
      },
      "contextTokens": 200000,
      "memorySearch": {
        "extraPaths": [
          "journal",
          "patterns",
          "docs",
          "research"
        ],
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m",
        "keepLastAssistants": 3,
        "tools": {
          "allow": [
            "exec",
            "read",
            "web_fetch",
            "browser",
            "process"
          ],
          "deny": [
            "memory_search",
            "memory_get"
          ]
        },
        "softTrim": {
          "maxChars": 4000,
          "headChars": 1500,
          "tailChars": 1500
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[Old tool result cleared]"
        }
      },
      "compaction": {
        "mode": "default",
        "reserveTokensFloor": 30000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000
        }
      },
      "heartbeat": {
        "every": "0m"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "sandbox": {
        "mode": "off"
      }
    }
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "models": [
          {
            "provider": "openai",
            "model": "gpt-4o-mini-transcribe",
            "capabilities": [
              "audio"
            ]
          }
        ],
        "echoTranscript": true
      }
    },
    "sessions": {
      "visibility": "agent"
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions",
    "tts": {
      "auto": "off",
      "provider": "openai"
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "reset": {
      "mode": "idle",
      "idleMinutes": 180
    },
    "maintenance": {
