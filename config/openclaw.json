{
  "gateway": {
    "port": 18789,
    "bind": "loopback",
    "mode": "local",
    "auth": {
      "mode": "token"
    },
    "channelHealthCheckMinutes": 120
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": [],
      "streaming": "partial"
    },
    "slack": {
      "enabled": true,
      "mode": "socket",
      "groupPolicy": "open",
      "streaming": "partial",
      "nativeStreaming": false
    }
  },
  "tools": {
    "media": {
      "audio": {
        "echoTranscript": true
      }
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      },
      "slack": {
        "enabled": true
      },
      "acpx": {
        "enabled": true,
        "config": {
          "permissionMode": "approve-all"
        }
      }
    }
  },
  "messages": {
    "tts": {
      "auto": "off",
      "provider": "openai"
    }
  },
  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true,
    "attachOnly": true,
    "executablePath": "/usr/bin/chromium",
    "defaultProfile": "openclaw",
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#FF4500"
      }
    }
  },
  "agents": {
    "defaults": {
      "maxConcurrent": 4,
      "model": {
        "primary": "anthropic/claude-opus-4-6",
        "fallbacks": ["openai/gpt-5.2", "anthropic/claude-sonnet-4-5"]
      },
      "models": {
        "anthropic/claude-sonnet-4-5": {
          "alias": "Sonnet"
        },
        "anthropic/claude-opus-4-6": {
          "alias": "Opus"
        },
        "anthropic/claude-haiku-4-5": {
          "alias": "Haiku"
        },
        "openrouter/openai/gpt-5.2-codex": {
          "alias": "Codex"
        }
      },
      "memorySearch": {
        "extraPaths": ["journal", "patterns", "docs"],
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "mmr": {
              "enabled": true,
              "lambda": 0.7
            },
            "temporalDecay": {
              "enabled": true,
              "halfLifeDays": 30
            }
          }
        }
      },
      "sandbox": {
        "mode": "off"
      },
      "contextTokens": 200000,
      "compaction": {
        "mode": "default",
        "reserveTokensFloor": 30000,
        "memoryFlush": {
          "enabled": false
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m",
        "keepLastAssistants": 3,
        "softTrim": {
          "maxChars": 4000,
          "headChars": 1500,
          "tailChars": 1500
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[Old tool result cleared]"
        },
        "tools": {
          "allow": ["exec", "read", "web_fetch", "browser", "process"],
          "deny": ["memory_search", "memory_get"]
        }
      },
      "heartbeat": {
        "every": "0m"
      }
    }
  },
  "session": {
    "reset": {
      "mode": "idle",
      "idleMinutes": 60
    },
    "maintenance": {
      "mode": "enforce",
      "pruneAfter": "30d",
      "maxEntries": 500,
      "maxDiskBytes": "2gb"
    }
  },
  "acp": {
    "enabled": true,
    "dispatch": {
      "enabled": true
    },
    "backend": "acpx",
    "defaultAgent": "codex",
    "allowedAgents": ["codex", "claude"],
    "maxConcurrentSessions": 4,
    "stream": {
      "coalesceIdleMs": 300,
      "maxChunkChars": 1200
    },
    "runtime": {
      "ttlMinutes": 120
    }
  },
  "hooks": {
    "internal": {
      "enabled": true
    }
  },
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "command": "qmd",
      "includeDefaultMemory": true,
      "update": {
        "interval": "5m",
        "debounceMs": 15000,
        "onBoot": true,
        "waitForBootSync": false
      },
      "limits": {
        "maxResults": 8,
        "maxSnippetChars": 2000,
        "timeoutMs": 5000
      },
      "paths": [
        {
          "path": "journal",
          "name": "journal",
          "pattern": "**/*.md"
        },
        {
          "path": "patterns",
          "name": "patterns",
          "pattern": "**/*.md"
        },
        {
          "path": "docs",
          "name": "docs",
          "pattern": "**/*.md"
        },
        {
          "path": "conversations",
          "name": "conversations",
          "pattern": "**/*.md"
        }
      ]
    }
  }
}
